-- ============================================================
--  ESP
-- ============================================================
local ESPCfg = Config['ESP']
local espKey = Enum.KeyCode[Config['General']['Binds']['ESP Toggle']]
local espObjects = {}

local function createESP(player)
    if player == LocalPlayer or not ESPCfg['Enabled'] then return end

    local text = Drawing.new("Text")
    text.Visible = false
    text.Color = Color3.fromRGB(255, 255, 255)
    text.Size = 14
    text.Font = 1
    text.Center = true
    text.Outline = true
    text.OutlineColor = Color3.fromRGB(0, 0, 0)

    espObjects[player] = { text = text }
end

local function removeESP(player)
    if espObjects[player] then
        if espObjects[player].text then
            espObjects[player].text:Remove()
        end
        espObjects[player] = nil
    end
end

-- Create ESP for existing players
for _, player in ipairs(Players:GetPlayers()) do
    createESP(player)
end

-- Handle new players
Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)

-- Update ESP
RunService.RenderStepped:Connect(function()
    if not ESPCfg['Enabled'] then
        for _, data in pairs(espObjects) do
            if data.text then data.text.Visible = false end
        end
        return
    end

    for player, data in pairs(espObjects) do
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local root = player.Character.HumanoidRootPart
            local hum = player.Character:FindFirstChild("Humanoid")

            if hum and hum.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)

                if onScreen then
                    data.text.Position = Vector2.new(screenPos.X, screenPos.Y - 30)
                    data.text.Text = player.DisplayName or player.Name
                    data.text.Visible = true

                    -- Highlight locked target with GREEN color
                    if player == LockedTarget then
                        data.text.Color = Color3.fromRGB(0, 255, 0)  -- Bright green for locked target
                        data.text.Size = 16  -- Slightly bigger
                    else
                        data.text.Color = Color3.fromRGB(255, 255, 255)  -- White for others
                        data.text.Size = 14
                    end
                else
                    data.text.Visible = false
                end
            else
                data.text.Visible = false
            end
        else
            data.text.Visible = false
        end
    end
end)

