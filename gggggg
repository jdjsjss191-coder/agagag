-- Find closest player
local function findTarget()
    local SA = Config['Silent Aim']
    local mousePos = UserInputService:GetMouseLocation()
    local bestTarget = nil
    local bestDist = math.huge
    local fov = SA['Selection'] == 'Target' and SA['FOV']['Lock'] or SA['FOV']['Automatic']
    local maxDist = SA['Max Distance']

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local hum = char:FindFirstChild("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")

            if hum and hum.Health > 0 and root then
                -- Check distance
                local dist3D = (root.Position - Camera.CFrame.Position).Magnitude
                if dist3D <= maxDist then
                    -- Check FOV
                    local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                    if onScreen then
                        local screenPos2D = Vector2.new(screenPos.X, screenPos.Y)
                        local dist2D = (screenPos2D - mousePos).Magnitude

                        if dist2D <= fov * 12 and dist2D < bestDist then
                            bestTarget = player
                            bestDist = dist2D
                        end
                    end
                end
            end
        end
    end

    return bestTarget
end

-- Get predicted position
local function getPredictedPosition(player)
    if not player or not player.Character then return nil end

    local SA = Config['Silent Aim']
    local hitPart = SA['Hit Location']['Hit Part'] or 'Head'
    local part = player.Character:FindFirstChild(hitPart)

    if not part then return nil end

    local pos = part.Position
    if SA['Prediction']['Enabled'] then
        local vel = part.AssemblyLinearVelocity or part.Velocity or Vector3.new(0, 0, 0)
        pos = pos + Vector3.new(vel.X * SA['Prediction']['X'], vel.Y * SA['Prediction']['Y'], 0)
    end

    return pos
end

-- Update tracer
RunService.RenderStepped:Connect(function()
    local TracerCfg = Config['Silent Aim']['Target Lock']['Tracer']
    
    if TracerCfg['Enabled'] and LockedTarget and LockedTarget.Character then
        local root = LockedTarget.Character:FindFirstChild("HumanoidRootPart")
        local hum = LockedTarget.Character:FindFirstChild("Humanoid")
        
        if root and hum and hum.Health > 0 then
            local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            if onScreen then
                local vpSize = Camera.ViewportSize
                TargetTracer.From = Vector2.new(vpSize.X / 2, vpSize.Y)
                TargetTracer.To = Vector2.new(screenPos.X, screenPos.Y)
                TargetTracer.Visible = true
            else
                TargetTracer.Visible = false
            end
        else
            TargetTracer.Visible = false
        end
    else
        TargetTracer.Visible = false
    end
end)

-- Hook Mouse.Hit for silent aim
if not getgenv().__SilentAimHooked then
    getgenv().__SilentAimHooked = true

    local mt = getrawmetatable(game)
    local oldIndex = mt.__index
    setreadonly(mt, false)

    mt.__index = newcclosure(function(self, key)
        if self == Mouse and key == "Hit" then
            local SA = Config['Silent Aim']
            if SA['Enabled'] then
                local target = nil

                if SA['Selection'] == 'Target' and LockedTarget then
                    target = LockedTarget
                    currentTarget = target
                elseif SA['Selection'] == 'Automatic' or (SA['Selection'] == 'Both' and not LockedTarget) then
                    target = findTarget()
                    currentTarget = target
                end

                if target then
                    local pos = getPredictedPosition(target)
                    if pos then
                        return CFrame.new(pos)
                    end
                end
            end
        end
        return oldIndex(self, key)
    end)

    setreadonly(mt, true)
    print("[Sacrifice] Silent Aim hook installed")
end

-- Target lock keybind
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    if lockKey and input.KeyCode == lockKey then
        if LockedTarget then
            LockedTarget = nil
            currentTarget = nil
            print("[Sacrifice] Target unlocked")
        else
            LockedTarget = findTarget()
            if LockedTarget then
                currentTarget = LockedTarget
                print("[Sacrifice] Locked onto:", LockedTarget.DisplayName or LockedTarget.Name)
            else
                print("[Sacrifice] No target found in FOV")
            end
        end
    end
end)

